<!--
Ekran gry. Gracz strzela w planszę przeciwnika i dostaje informację zwrotną.
Aktualizuje plansze, odlicza timer na turę. Dla informacji, jest również legenda.
-->
    
<UserControl x:Class="Statki.GameScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Statki"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">

    <!-- Własny styl dla A-J oraz 1-10 -->
    <UserControl.Resources>
        <Style x:Key="Styl" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontFamily" Value="Candara"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Tło -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/wall2.jpg"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="62"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!-- Timer tury -->
        <TextBlock x:Name="TurnTimer"
                   Grid.Column="0" Grid.Row="0"
                   Foreground="White"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="(Timer)"
                   FontSize="36" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="0,0,0,5" FontFamily="Candara"/>
        
        <!-- Informacja o planszy przeciwnika -->
        <TextBlock Grid.Column="0" Grid.Row="1"
                   Foreground="White"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="Plansza przeciwnika"
                   FontSize="36" FontWeight="Bold"
                   HorizontalAlignment="Left" VerticalAlignment="Center"
                   Margin="15" FontFamily="Candara" Padding="5"/>

        <!-- Informacja o planszy gracza -->
        <TextBlock Grid.Row="2" Grid.Column="0"
                   Foreground="White"
                   TextWrapping="Wrap"
                   TextAlignment="Center"
                   Text="Twoja plansza"
                   FontSize="40" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Margin="15" FontFamily="Candara" Padding="15,5"/>

        <!-- Plansza przeciwnika z etykietami -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <!-- A-J -->
                <RowDefinition Height="30"/>
                <!-- Plansza -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- 1-10 -->
                <ColumnDefinition Width="30"/>
                <!-- Plansza -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- A-J -->
            <UniformGrid Grid.Row="0" Grid.Column="1" Columns="10">
                <TextBlock Text="A" Style="{StaticResource Styl}"/>
                <TextBlock Text="B" Style="{StaticResource Styl}"/>
                <TextBlock Text="C" Style="{StaticResource Styl}"/>
                <TextBlock Text="D" Style="{StaticResource Styl}"/>
                <TextBlock Text="E" Style="{StaticResource Styl}"/>
                <TextBlock Text="F" Style="{StaticResource Styl}"/>
                <TextBlock Text="G" Style="{StaticResource Styl}"/>
                <TextBlock Text="H" Style="{StaticResource Styl}"/>
                <TextBlock Text="I" Style="{StaticResource Styl}"/>
                <TextBlock Text="J" Style="{StaticResource Styl}"/>
            </UniformGrid>

            <!-- 1-10 -->
            <UniformGrid Grid.Row="1" Grid.Column="0" Rows="10">
                <TextBlock Text="1" Style="{StaticResource Styl}"/>
                <TextBlock Text="2" Style="{StaticResource Styl}"/>
                <TextBlock Text="3" Style="{StaticResource Styl}"/>
                <TextBlock Text="4" Style="{StaticResource Styl}"/>
                <TextBlock Text="5" Style="{StaticResource Styl}"/>
                <TextBlock Text="6" Style="{StaticResource Styl}"/>
                <TextBlock Text="7" Style="{StaticResource Styl}"/>
                <TextBlock Text="8" Style="{StaticResource Styl}"/>
                <TextBlock Text="9" Style="{StaticResource Styl}"/>
                <TextBlock Text="10" Style="{StaticResource Styl}"/>
            </UniformGrid>

            <!-- Główna plansza przeciwnika -->
            <UniformGrid x:Name="OpponentGrid"
                         Grid.Row="2" Grid.Column="1"
                         Rows="10" Columns="10"
                         Width="300" Height="300"
                         HorizontalAlignment="Right" VerticalAlignment="Top"
                         Margin="0"/>
        </Grid>

        <!-- Plansza gracza z etykietami -->
        <Grid Grid.Row="2" Grid.Column="1" Margin="10,10,10,10">
            <Grid.RowDefinitions>
                <!-- A-J -->
                <RowDefinition Height="30"/>
                <!-- Plansza -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <!-- 1-10 -->
                <ColumnDefinition Width="30"/>
                <!-- Plansza -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- A-J -->
            <UniformGrid Grid.Row="0" Grid.Column="1" Columns="10">
                <TextBlock Text="A" Style="{StaticResource Styl}"/>
                <TextBlock Text="B" Style="{StaticResource Styl}"/>
                <TextBlock Text="C" Style="{StaticResource Styl}"/>
                <TextBlock Text="D" Style="{StaticResource Styl}"/>
                <TextBlock Text="E" Style="{StaticResource Styl}"/>
                <TextBlock Text="F" Style="{StaticResource Styl}"/>
                <TextBlock Text="G" Style="{StaticResource Styl}"/>
                <TextBlock Text="H" Style="{StaticResource Styl}"/>
                <TextBlock Text="I" Style="{StaticResource Styl}"/>
                <TextBlock Text="J" Style="{StaticResource Styl}"/>
            </UniformGrid>

            <!-- 1-10 -->
            <UniformGrid Grid.Row="1" Grid.Column="0" Rows="10">
                <TextBlock Text="1" Style="{StaticResource Styl}"/>
                <TextBlock Text="2" Style="{StaticResource Styl}"/>
                <TextBlock Text="3" Style="{StaticResource Styl}"/>
                <TextBlock Text="4" Style="{StaticResource Styl}"/>
                <TextBlock Text="5" Style="{StaticResource Styl}"/>
                <TextBlock Text="6" Style="{StaticResource Styl}"/>
                <TextBlock Text="7" Style="{StaticResource Styl}"/>
                <TextBlock Text="8" Style="{StaticResource Styl}"/>
                <TextBlock Text="9" Style="{StaticResource Styl}"/>
                <TextBlock Text="10" Style="{StaticResource Styl}"/>
            </UniformGrid>

            <!-- Główna plansza gracza -->
            <UniformGrid x:Name="PlayerGrid"
                         Grid.Row="1" Grid.Column="1"
                         Rows="10" Columns="10"
                         Width="300" Height="300"
                         HorizontalAlignment="Right" VerticalAlignment="Top"
                         Margin="0"/>
        </Grid>

        <!-- Informacja o turze -->
        <TextBlock x:Name="TurnInfo"
                   Foreground="White"
                   Grid.Row="0" Grid.Column="1"
                   Text="(Info o turze)"
                   TextWrapping="Wrap"
                   Margin="15,5,0,0"
                   FontSize="32" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   FontFamily="Candara"/>
        
        <!-- Wynik gry -->
        <TextBlock x:Name="ResultText"
                   Foreground="White"
                   Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Text="ZWYCIĘSTWO!"
                   Margin="5"
                   FontSize="36" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="Candara"
                   Visibility="Hidden"/>
        
        <!-- Przycisk powrotu z gry -->
        <Button x:Name="BackButton"
                Grid.Row="1"
                Grid.RowSpan="2"
                Margin="20"
                FontSize="40"
                FontWeight="Bold"
                Padding="20,10"
                Foreground="White"
                Background="SlateGray"
                BorderBrush="White"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Content="Powrót"
                Click="BackButton_Click"
                Visibility="Collapsed"
                IsEnabled="False"/>
        
        <!-- Legenda -->
        <StackPanel x:Name="Legenda"
                    Grid.Row="1"
                    Grid.RowSpan="2"
                    Background="LightSlateGray"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Visibility="Visible">

            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Rectangle Width="35" Height="35" Fill="LightBlue" Stroke="Black" Margin="0,0,5,0"/>
                <TextBlock Text="Pole nieodkryte" FontSize="24" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Rectangle Width="35" Height="35" Fill="LightPink" Stroke="Black" Margin="0,0,5,0"/>
                <TextBlock Text="Trafiony statek" FontSize="24" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Rectangle Width="35" Height="35" Fill="Red" Stroke="Black" Margin="0,0,5,0"/>
                <TextBlock Text="Zatopiony statek" FontSize="24" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Rectangle Width="35" Height="35" Fill="DarkBlue" Stroke="Black" Margin="0,0,5,0"/>
                <TextBlock Text="Pudło" FontSize="24" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,5">
                <Rectangle Width="35" Height="35" Fill="SpringGreen" Stroke="Black" Margin="0,0,5,0"/>
                <TextBlock Text="Twój statek" FontSize="24" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
        
        <!-- Przycisk od legendy -->
        <Button x:Name="Button_legenda"
                Content="Ukryj legendę"
                Grid.Row="2"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Padding="15,5"
                FontSize="28"
                FontFamily="Candara"
                Margin="20"
                Background="FloralWhite"
                Click="Legend_Click"/>
    </Grid>
</UserControl>

