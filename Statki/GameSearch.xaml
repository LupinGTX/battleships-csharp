<!--
Ekran wyszukiwania. Przechodzi do gry, jeśli ją znajdzie.
Można anulować wyszukiwanie, również wyświetla błędy.
-->
    
<UserControl x:Class="Statki.GameSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Statki"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">
    <Grid>
        <!-- Tło -->
        <Grid.Background>
            <ImageBrush ImageSource="/Images/Battleship 3 (dark).jpg"/>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Nagłówek -->
        <TextBlock x:Name="StatusBlock"
                   Text="Szukanie gry..."
                   FontSize="80" 
                   FontFamily="Candara" 
                   TextAlignment="Center"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Grid.Row="0"
                   TextWrapping="Wrap" 
                   Margin="20"
                   Width="400"/>

        <!-- Timer -->
        <TextBlock Name="SearchTimer"
                   Text="(Timer)"
                   FontSize="100" FontFamily="Candara" TextAlignment="Center"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Top"
                   Grid.Row="1"
                   TextWrapping="Wrap" Width="400" Margin="40"/>

        <!-- Przycisk anulowania -->
        <Button Content="Anuluj"
                Background="Wheat"
                FontSize="60"
                FontFamily="Candara"
                HorizontalAlignment="Center"
                Margin="20"
                Grid.Row="2"
                Click="Cancel_Click"
                Height="100" Width="350"/>
    </Grid>
</UserControl>