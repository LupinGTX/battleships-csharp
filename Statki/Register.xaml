<UserControl x:Class="Statki.Register"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Statki"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">
    <Grid>
        <!-- Tło w postaci obrazka -->
        <Grid.Background>
            <ImageBrush ImageSource="\Images\Battleship 3 (dark).jpg"/>
        </Grid.Background>

        <!-- Główna kolumna z kontrolkami formularza -->
        <StackPanel Margin="50">

            <!-- Nagłówek formularza -->
            <TextBlock FontSize="60"
                       FontWeight="Bold"
                       FontFamily="Candara"
                       TextAlignment="Center" 
                       TextWrapping="Wrap" 
                       Text="Rejestracja"
                       Foreground="AntiqueWhite"
                       Margin="10"/>

            <!-- Komunikat o błędach (domyślnie ukryty) -->
            <TextBlock x:Name="ErrorBlock"
                       Visibility="Collapsed"
                       Margin="20"
                       Foreground="Orange"
                       FontSize="20"
                       FontWeight="Bold"
                       FontFamily="Candara"
                       TextAlignment="Center" 
                       TextWrapping="Wrap"/>

            <!-- Tekst dla pola nazwy użytkownika -->
            <TextBlock Text="Nazwa użytkownika:"
                       FontSize="32"
                       FontWeight="Bold"
                       FontFamily="Candara"
                       TextAlignment="Left"
                       TextWrapping="Wrap"
                       Foreground="AntiqueWhite"
                       Margin="15,0"/>

            <!-- Pole tekstowe na nazwę użytkownika -->
            <TextBox x:Name="NicknameBox"
                     Margin="15"
                     Background="WhiteSmoke"
                     FontSize="40"
                     Foreground="Gray"/>

            <!-- Tekst dla pierwszego hasła -->
            <TextBlock FontSize="32"
                       FontWeight="Bold"
                       FontFamily="Candara"
                       TextAlignment="Left" 
                       TextWrapping="Wrap" 
                       Text="Hasło:"
                       Foreground="AntiqueWhite"
                       Margin="15,0"/>

            <!-- Pierwsze pole hasła -->
            <PasswordBox x:Name="PasswordBox1"
                         Margin="15"
                         Background="WhiteSmoke"
                         FontSize="40"
                         Tag="Hasło"
                         Foreground="Gray"/>

            <!-- Tekst do powtórzenia hasła -->
            <TextBlock x:Name="RepeatPasswordText"
                       FontSize="32"
                       FontWeight="Bold"
                       FontFamily="Candara"
                       TextAlignment="Left" 
                       TextWrapping="Wrap" 
                       Text="Powtórz hasło:"
                       Foreground="AntiqueWhite"
                       Margin="15,0"/>

            <!-- Drugie pole hasła -->
            <PasswordBox x:Name="PasswordBox2"
                         Margin="15"
                         Background="WhiteSmoke"
                         FontSize="40"
                         Tag="Hasło"
                         Foreground="Gray"/>

            <!-- Przycisk zatwierdzający rejestrację -->
            <Button Content="Zatwierdź"
                    Background="Wheat"
                    FontSize="42"
                    Margin="15"
                    Click="Confirm_Click"
                    HorizontalAlignment="Center"
                    Padding="50,5"/>
        </StackPanel>

        <!-- Przycisk powrotu do logowania -->
        <Button x:Name="Login_Button"
                Content="Powrót do logowania"
                VerticalAlignment="Bottom"
                HorizontalAlignment="Center"
                Padding="20,5"
                Margin="20"
                FontSize="32"
                Background="Transparent"
                Foreground="AntiqueWhite"
                BorderThickness="0"
                Click="Login_Click"/>
    </Grid>
</UserControl>
