<!--Główne okno aplikacji WPF dla gry.
    Służy jako kontener dla dynamicznie zmienianych ekranów (logowanie, menu, gra itd.),
    które są ładowane do ContentControl "MainContent".-->
<Window x:Class="Statki.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Statki"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="800" Width="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

<!--Główne miejsce, w którym będą wyświetlane kolejne ekrany aplikacji (UserControl),
    takie jak: Login, Register, MainMenu, GameScreen itd.
    Każdy z nich jest dynamicznie ustawiany w MainWindow.xaml.cs odpowiednimi metodami.-->
    <Grid Name="BoardGrid" Margin="0">
        <ContentControl Name="MainContent"/>
    </Grid>
</Window>
